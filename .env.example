# Environment Configuration Template
# Copy this file to .env and fill in actual values

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-change-me-in-production

# ============================================================================
# DATABASE
# ============================================================================
DB_USER=admin
DB_PASSWORD=your-secure-database-password
DB_NAME=fithub_prod
DATABASE_URL=postgresql://admin:your-password@postgres:5432/fithub_prod

# For AWS RDS (if not using local Postgres)
# DATABASE_URL=postgresql://admin:password@fithub-prod-cluster.us-east-1.rds.amazonaws.com:5432/fithub_prod

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://redis:6379/0

# ============================================================================
# API KEYS
# ============================================================================
GOOGLE_SCHOLAR_API_KEY=86ea0ba4485ffff75a64df040c750ae7fb8455e13da606ab71c7bb70fcb6fdf2
NLM_API_KEY=951d55d8d51dc86852251ada4339ccb79308
CROSSREF_EMAIL=sanchitpanda490@gmail.com

# ============================================================================
# FRONTEND
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.fithub.app
NEXT_PUBLIC_ENVIRONMENT=production

# ============================================================================
# AWS (for Terraform & GitHub Actions)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ============================================================================
# DEPLOYMENT
# ============================================================================
DOMAIN_NAME=fithub.app
STAGING_DOMAIN=staging.fithub.app

# ============================================================================
# MONITORING & ALERTS
# ============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
